{
  "name": "obsidian-orrery",
  "version": "1.0.5",
  "description": "Render your vault's link graph as a cinematic, auto-rotating 3D orrery.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian-plugin",
    "graph",
    "3d",
    "visualization"
  ],
  "author": "c-miles",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/three": "^0.184.1",
    "esbuild": "0.20.0",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.2",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "3d-force-graph": "^1.80.0",
    "three": "^0.184.0",
    "three-spritetext": "^1.10.0"
  }
}
